# ==================== PANEL DE ADMINISTRACIÓN ====================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
JWT_SECRET=una_clave_secreta_muy_larga_y_segura

# ==================== SERVIDOR ====================
